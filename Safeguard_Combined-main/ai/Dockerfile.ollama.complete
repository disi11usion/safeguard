FROM ubuntu:22.04

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV OLLAMA_HOST=0.0.0.0
ENV OLLAMA_ORIGINS=*

# Install dependencies
RUN set -eux; \
printf "deb http://archive.ubuntu.com/ubuntu jammy main restricted universe multiverse\n\
deb http://archive.ubuntu.com/ubuntu jammy-updates main restricted universe multiverse\n\
deb http://security.ubuntu.com/ubuntu jammy-security main restricted universe multiverse\n" \
> /etc/apt/sources.list; \
apt-get -o Acquire::Retries=5 update && apt-get -o Acquire::Retries=5 -y full-upgrade && apt-get -o Acquire::Retries=5 install -y --fix-missing \
    curl \
    wget \
    ca-certificates \
    zstd \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama
RUN curl -fsSL https://ollama.ai/install.sh | sh

# Create startup script
RUN echo '#!/bin/bash\n\
echo "Starting Ollama..."\n\
ollama serve &\n\
echo "Waiting for Ollama to start..."\n\
sleep 10\n\
echo "Downloading tinyllama model (very fast)..."\n\
ollama pull tinyllama\n\
echo "tinyllama model downloaded successfully!"\n\
echo "Ollama is ready to use!"\n\
wait' > /start.sh && chmod +x /start.sh

# Expose port
EXPOSE 11434

# Start the service

CMD ["/start.sh"]

