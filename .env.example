# ============================================================================
# Safeguard AI · environment template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ============================================================================

# ─── Market Data ───
# Polygon.io (stocks / crypto / forex)
POLYGON_API_KEY=__REPLACE_ME__
# TwelveData (commodities backup)
TWELVE_DATA_API_KEY=__REPLACE_ME__
# Polygon secondary key for whale tracking (optional)
POLYGON_WHALE_API_KEY=__REPLACE_ME__

# ─── LLM ───
# OpenAI (gpt-4o-mini powers the AI portfolio summary)
CHATGPT_API_KEY=__REPLACE_ME__
CHATGPT_BASE_URL=https://api.openai.com/v1/
# Local Ollama (used as fallback inside Docker)
OLLAMA_BASE_URL=http://ollama:11434

# ─── On-chain (whale tracking) ───
ETHERSCAN_API_KEY=__REPLACE_ME__
BLOCKCYPHER_API_KEY=__REPLACE_ME__

# ─── News & Events ───
ALPHAVANTAGE_API_KEY=__REPLACE_ME__
FRED_API_KEY=__REPLACE_ME__
NEWSDATA_API_KEY=__REPLACE_ME__
NEWSAPI_API_KEY=__REPLACE_ME__
MEDIASTACK_API_KEY=__REPLACE_ME__
CRYPTO_PANIC_API_KEY=__REPLACE_ME__
CRYPTO_COMPARE_API_KEY=__REPLACE_ME__

# ─── Social ───
REDDIT_CLIENT_ID=__REPLACE_ME__
REDDIT_CLIENT_SECRET=__REPLACE_ME__
REDDIT_USER_AGENT=safeguard-app by u/__REPLACE_ME__
YOUTUBE_API_KEY=__REPLACE_ME__

# ─── Database ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__REPLACE_ME__
POSTGRES_DB=financeHub
DATABASE_URL=postgresql://postgres:__REPLACE_ME__@db:5432/financeHub
# Local dev (not Docker):
# DATABASE_URL=postgresql://postgres:__REPLACE_ME__@localhost:5432/financeHub

# ─── Auth / JWT ───
SECRET_KEY=__REPLACE_ME__
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300
FORCE_ALL_USERS_ADMIN_DEV=false
OTP_DEV_MODE=true
ADMIN_USERS_ALLOWLIST=

# ─── Feature flags ───
USING_MOCK_DATA=False

# ─── Payments (Stripe) ───
# Test keys live at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=__REPLACE_ME__
STRIPE_PUBLISHABLE_KEY=__REPLACE_ME__
STRIPE_WEBHOOK_SECRET=__REPLACE_ME__
STRIPE_PRICE_BASIC_MONTHLY=__REPLACE_ME__
STRIPE_PRICE_BASIC_YEARLY=__REPLACE_ME__

# ─── Payments (PayPal) ───
# Sandbox at https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=__REPLACE_ME__
PAYPAL_CLIENT_SECRET=__REPLACE_ME__
PAYPAL_MODE=sandbox

# ─── OTP / SendGrid ───
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
OTP_TTL_SECONDS=300
OTP_MIN_INTERVAL_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_IDP_ISSUER=safeguard-otp
OTP_IDP_AUDIENCE=safeguard-app
ALLOW_VIRTUAL_USERS=false

# ─── SMTP (fallback when SendGrid unavailable) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=__REPLACE_ME__
SMTP_PASS=__REPLACE_ME__
SMTP_FROM=__REPLACE_ME__

# ─── Frontend (Vite) ───
VITE_PAYPAL_CLIENT_ID=__REPLACE_ME__
