{
  "_meta": {
    "description": "Asset class taxonomy used by stress engine. All asset shocks are defined per class. by_symbol takes precedence over by_category_fallback.",
    "version": "v2",
    "last_updated": "2026-05-02",
    "changelog": [
      "v1 (2026-04-29): initial 18 hardcoded symbols",
      "v2 (2026-05-02): expanded to 50+ symbols. Added consumer staples (KO/JNJ/PG/WMT), payment processors (V/MA), media (DIS/MCD), energy (XOM/CVX), ADR/EM stocks (BABA/JD/NIO/TSM/PDD/BIDU), crypto alts (SOL/BNB/ADA/XRP/DOGE/AVAX), precious metal ETFs/synonyms (GLD/IAU/SLV/XAU/XAG). Aligns by_symbol with factor_loadings.json per_symbol coverage."
    ],
    "by_symbol_groups": {
      "crypto_major": ["BTC", "ETH"],
      "crypto_alt":   ["SOL", "BNB", "ADA", "XRP", "DOGE", "AVAX"],
